{
  "openapi": "3.0.0",
  "info": {
    "title": "Acme Corp E-Commerce API",
    "version": "2.0.0",
    "description": "Official API for managing users, product catalogs, and order fulfillment pipelines."
  },
  "servers": [
    {
      "url": "http://localhost:3000/api",
      "description": "Development Server"
    }
  ],
  "tags": [
    {
      "name": "E-Commerce Platform"
    }
  ],
  "paths": {
    "/api": {
      "get": {
        "summary": "Auto-generated GET /api",
        "responses": {
          "default": {
            "description": "Default fallback response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "version": {}
                  },
                  "required": [
                    "status",
                    "version"
                  ]
                }
              }
            }
          }
        },
        "tags": [
          "E-Commerce Platform"
        ]
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Authenticate User",
        "description": "Authenticates a user and returns a signed JWT session token.",
        "tags": [
          "Authentication",
          "E-Commerce Platform"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string"
                  },
                  "password": {}
                },
                "required": [
                  "email",
                  "password"
                ]
              }
            }
          }
        },
        "responses": {
          "default": {
            "description": "Generic status from T[\"status\"]",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": {
                      "type": "string"
                    },
                    "user": {
                      "type": "object",
                      "properties": {
                        "email": {}
                      },
                      "required": [
                        "email"
                      ]
                    }
                  },
                  "required": [
                    "token",
                    "user"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "summary": "Register New Account",
        "description": "Provisions a new user account in the system and sends a verification email.",
        "tags": [
          "Authentication",
          "E-Commerce Platform"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "firstName": {
                    "type": "string"
                  },
                  "lastName": {},
                  "email": {},
                  "password": {},
                  "company": {
                    "oneOf": [
                      {}
                    ]
                  }
                },
                "required": [
                  "firstName",
                  "lastName",
                  "email",
                  "password"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Status 201",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "oneOf": [
                        {
                          "type": "boolean",
                          "enum": [
                            false
                          ]
                        },
                        {
                          "type": "boolean",
                          "enum": [
                            true
                          ]
                        }
                      ]
                    },
                    "id": {
                      "type": "string"
                    },
                    "email": {}
                  },
                  "required": [
                    "success",
                    "id",
                    "email"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "summary": "Logout User",
        "description": "Invalidates the current user session and clears authentication cookies.",
        "tags": [
          "Authentication",
          "E-Commerce Platform"
        ],
        "responses": {
          "default": {
            "description": "Generic status from T[\"status\"]",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "oneOf": [
                        {
                          "type": "boolean",
                          "enum": [
                            false
                          ]
                        },
                        {
                          "type": "boolean",
                          "enum": [
                            true
                          ]
                        }
                      ]
                    },
                    "message": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "success",
                    "message"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/products": {
      "get": {
        "summary": "List Catalog Products",
        "description": "Returns a paginated list of all active products in the store catalog.",
        "tags": [
          "Catalog",
          "E-Commerce Platform"
        ],
        "parameters": [
          {
            "name": "category",
            "in": "query",
            "required": false,
            "schema": {
              "oneOf": [
                {
                  "type": "string"
                }
              ]
            }
          },
          {
            "name": "inStock",
            "in": "query",
            "required": false,
            "schema": {
              "oneOf": [
                {
                  "type": "string"
                }
              ]
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "oneOf": [
                {
                  "type": "string"
                }
              ]
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "oneOf": [
                {
                  "type": "string"
                }
              ]
            }
          }
        ],
        "responses": {
          "default": {
            "description": "Generic status from T[\"status\"]",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "name": {},
                          "description": {},
                          "price": {
                            "type": "number"
                          },
                          "currency": {},
                          "inventoryCount": {},
                          "categories": {
                            "type": "array",
                            "items": {}
                          }
                        },
                        "required": [
                          "id",
                          "name",
                          "description",
                          "price",
                          "currency",
                          "inventoryCount",
                          "categories"
                        ]
                      }
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "page": {},
                        "limit": {},
                        "total": {}
                      },
                      "required": [
                        "page",
                        "limit",
                        "total"
                      ]
                    }
                  },
                  "required": [
                    "data",
                    "meta"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/products/{productId}": {
      "get": {
        "summary": "Retrieve Product Details",
        "description": "Fetches the full product details, including pricing and inventory data, by its unique ID.",
        "tags": [
          "Catalog",
          "E-Commerce Platform"
        ],
        "parameters": [
          {
            "name": "productId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "default": {
            "description": "Generic status from T[\"status\"]",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "name": {},
                    "description": {},
                    "price": {
                      "type": "number"
                    },
                    "currency": {},
                    "inventoryCount": {},
                    "categories": {
                      "type": "array",
                      "items": {}
                    }
                  },
                  "required": [
                    "id",
                    "name",
                    "description",
                    "price",
                    "currency",
                    "inventoryCount",
                    "categories"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/orders": {
      "post": {
        "summary": "Create Order",
        "description": "Places a new order for a product and triggers the fulfillment pipeline.",
        "tags": [
          "Orders",
          "E-Commerce Platform"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "productId": {
                    "type": "string"
                  },
                  "quantity": {
                    "type": "number"
                  },
                  "shippingAddress": {
                    "type": "object",
                    "properties": {
                      "line1": {},
                      "city": {},
                      "countryCode": {},
                      "postalCode": {}
                    },
                    "required": [
                      "line1",
                      "city",
                      "countryCode",
                      "postalCode"
                    ]
                  }
                },
                "required": [
                  "productId",
                  "quantity",
                  "shippingAddress"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Status 201",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "oneOf": [
                        {
                          "type": "boolean",
                          "enum": [
                            false
                          ]
                        },
                        {
                          "type": "boolean",
                          "enum": [
                            true
                          ]
                        }
                      ]
                    },
                    "orderId": {
                      "type": "string"
                    },
                    "status": {},
                    "estimatedShippingDate": {}
                  },
                  "required": [
                    "success",
                    "orderId",
                    "status",
                    "estimatedShippingDate"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/orders/tracking/{trackingNumber}": {
      "get": {
        "summary": "Get Shipment Tracking",
        "description": "Fetches real-time GPS tracking data for a specific shipment.",
        "tags": [
          "Logistics",
          "E-Commerce Platform"
        ],
        "parameters": [
          {
            "name": "trackingNumber",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "default": {
            "description": "Generic status from T[\"status\"]",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "trackingNumber": {
                      "type": "string"
                    },
                    "status": {},
                    "location": {
                      "type": "object",
                      "properties": {
                        "lat": {
                          "type": "number"
                        },
                        "lng": {}
                      },
                      "required": [
                        "lat",
                        "lng"
                      ]
                    },
                    "estimatedDelivery": {}
                  },
                  "required": [
                    "trackingNumber",
                    "status",
                    "location",
                    "estimatedDelivery"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/docs": {
      "get": {
        "summary": "Auto-generated GET /api/docs",
        "responses": {
          "default": {
            "description": "Generic status from T[\"status\"]",
            "content": {
              "application/json": {
                "schema": {
