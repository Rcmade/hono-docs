{
  "openapi": "3.0.0",
  "info": {
    "title": "My API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000/api"
    }
  ],
  "tags": [
    {
      "name": "User Routes"
    }
  ],
  "paths": {
    "/user/me": {
      "get": {
        "summary": "Get Current User",
        "description": "Returns the profile of the currently authenticated user.",
        "responses": {
          "default": {
            "description": "Default fallback response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "name": {},
                    "email": {}
                  },
                  "required": [
                    "id",
                    "name",
                    "email"
                  ]
                }
              }
            }
          }
        },
        "tags": [
          "User Routes"
        ]
      }
    },
    "/user": {
      "get": {
        "summary": "List Users",
        "description": "Retrieves a paginated list of users.",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "oneOf": [
                {
                  "type": "string"
                }
              ]
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "oneOf": [
                {
                  "type": "string"
                }
              ]
            }
          },
          {
            "name": "search",
            "in": "query",
            "required": false,
            "schema": {
              "oneOf": [
                {
                  "type": "string"
                }
              ]
            }
          }
        ],
        "responses": {
          "default": {
            "description": "Default fallback response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {}
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "page": {
                          "type": "string"
                        },
                        "limit": {},
                        "search": {
                          "oneOf": [
                            {}
                          ]
                        }
                      },
                      "required": [
                        "page",
                        "limit"
                      ]
                    },
                    "total": {
                      "type": "number"
                    }
                  },
                  "required": [
                    "data",
                    "meta",
                    "total"
                  ]
                }
              }
            }
          }
        },
        "tags": [
          "UserList"
        ]
      },
      "post": {
        "summary": "Create User",
        "description": "Creates a new user in the system.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "email": {},
                  "age": {
                    "oneOf": [
                      {
                        "type": "number"
                      }
                    ]
                  }
                },
                "required": [
                  "name",
                  "email"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Status 201",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "oneOf": [
                        {
                          "type": "boolean",
                          "enum": [
                            false
                          ]
                        },
                        {
                          "type": "boolean",
                          "enum": [
                            true
                          ]
                        }
                      ]
                    },
                    "user": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string"
                        },
                        "email": {},
                        "age": {
                          "oneOf": [
                            {
                              "type": "number"
                            }
                          ]
                        },
                        "id": {}
                      },
                      "required": [
                        "name",
                        "email",
                        "id"
                      ]
                    }
                  },
                  "required": [
                    "success",
                    "user"
                  ]
                }
              }
            }
          }
        },
        "tags": [
          "User Routes"
        ]
      }
    },
    "/user/{id}": {
      "get": {
        "summary": "Get User by ID",
        "description": "Retrieves a specific user's details by their UUID.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Status 200",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "name": {},
                    "email": {},
                    "age": {
                      "type": "number"
                    }
                  },
                  "required": [
                    "id",
                    "name",
                    "email",
                    "age"
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Status 404",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "oneOf": [
                        {
                          "type": "boolean",
                          "enum": [
                            false
                          ]
                        },
                        {
                          "type": "boolean",
                          "enum": [
                            true
                          ]
                        }
                      ]
                    },
                    "message": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "success",
                    "message"
                  ]
                }
              }
            }
          }
        },
        "tags": [
          "User Routes"
        ]
      },
      "put": {
        "summary": "Update User",
        "description": "Updates an existing user's information.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "email": {},
                  "age": {
                    "oneOf": [
                      {
                        "type": "number"
                      }
                    ]
                  }
                },
                "required": [
                  "name",
                  "email"
                ]
              }
            }
          }
        },
        "responses": {
          "default": {
            "description": "Default fallback response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "oneOf": [
                        {
                          "type": "boolean",
                          "enum": [
                            false
                          ]
                        },
                        {
                          "type": "boolean",
                          "enum": [
                            true
                          ]
                        }
                      ]
                    },
                    "updated": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string"
                        },
                        "email": {},
                        "age": {
                          "oneOf": [
                            {
                              "type": "number"
                            }
                          ]
                        },
                        "id": {}
                      },
                      "required": [
                        "name",
                        "email",
                        "id"
                      ]
                    }
                  },
                  "required": [
                    "success",
                    "updated"
                  ]
                }
              }
            }
          }
        },
        "tags": [
          "User Routes"
        ]
      },
      "delete": {
        "summary": "Delete User",
        "description": "Removes a user from the system.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "default": {
            "description": "Default fallback response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "oneOf": [
                        {
                          "type": "boolean",
                          "enum": [
                            false
                          ]
                        },
                        {
                          "type": "boolean",
                          "enum": [
                            true
                          ]
                        }
                      ]
                    },
                    "deletedId": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "success",
                    "deletedId"
                  ]
                }
              }
            }
          }
        },
        "tags": [
          "User Routes"
        ]
      }
    },
    "/user/profile/context": {
      "patch": {
        "summary": "Update Profile Context (Header & Cookie)",
        "description": "Demonstrates header and cookie validation.",
        "parameters": [
          {
            "name": "x-api-key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "user-agent",
            "in": "header",
            "required": false,
            "schema": {
              "oneOf": [
                {
                  "type": "string"
                }
              ]
            }
          },
          {
            "name": "session_id",
            "in": "cookie",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "default": {
            "description": "Default fallback response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "oneOf": [
                        {
                          "type": "boolean",
                          "enum": [
                            false
                          ]
                        },
                        {
                          "type": "boolean",
                          "enum": [
                            true
                          ]
                        }
                      ]
                    },
                    "headers": {
                      "type": "object",
                      "properties": {
                        "x-api-key": {
                          "type": "string"
                        },
                        "user-agent": {
                          "oneOf": [
                            {}
                          ]
                        }
                      },
                      "required": [
                        "x-api-key"
                      ]
                    },
                    "cookies": {
                      "type": "object",
                      "properties": {
                        "session_id": {}
                      },
                      "required": [
                        "session_id"
                      ]
                    }
                  },
                  "required": [
                    "success",
                    "headers",
                    "cookies"
                  ]
                }
              }
            }
          }
        },
        "tags": [
          "User Routes"
        ]
      }
    },
    "/user/profile/bio": {
      "post": {
        "summary": "Update Bio (Form Data)",
        "description": "Demonstrates form data (body) validation.",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "bio": {
                    "type": "string"
                  },
                  "avatarUrl": {
                    "oneOf": [
                      {}
                    ]
                  }
                },
                "required": [
                  "bio"
                ]
              }
            }
          }
        },
        "responses": {
          "default": {
            "description": "Default fallback response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "oneOf": [
                        {
                          "type": "boolean",
                          "enum": [
                            false
                          ]
                        },
                        {
                          "type": "boolean",
                          "enum": [
                            true
                          ]
                        }
                      ]
                    },
                    "form": {
                      "type": "object",
                      "properties": {
                        "bio": {
                          "type": "string"
                        },
                        "avatarUrl": {
                          "oneOf": [
                            {}
                          ]
                        }
                      },
                      "required": [
                        "bio"
                      ]
                    }
                  },
                  "required": [
                    "success",
                    "form"
                  ]
                }
              }
            }
          }
        },
        "tags": [
          "User Routes"
        ]
      }
    },
    "/user/{id}/preferences": {
      "put": {
        "summary": "Update Advanced Preferences",
        "description": "Demonstrates complex Zod schemas like enums, unions, nested objects, arrays, and records.",
        "tags": [
          "Preferences",
          "Advanced",
          "User Routes"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "notifications": {
                    "type": "object",
                    "properties": {
                      "frequency": {
                        "type": "string",
                        "enum": [
                          "never",
                          "daily",
                          "weekly"
                        ]
                      },
                      "email": {
                        "oneOf": [
                          {
                            "type": "boolean",
                            "enum": [
                              false
                            ]
                          },
                          {
                            "type": "boolean",
                            "enum": [
                              true
                            ]
                          }
                        ]
                      },
                      "push": {}
                    },
                    "required": [
                      "frequency"
                    ]
                  },
                  "roles": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": [
                        "admin",
                        "editor",
                        "viewer"
                      ]
                    }
                  },
                  "theme": {
                    "type": "string",
                    "enum": [
                      "light",
                      "dark",
                      "system"
                    ],
                    "nullable": true
                  },
                  "metadata": {
                    "oneOf": [
                      {}
                    ]
                  }
                },
                "required": [
                  "notifications",
                  "roles"
                ]
              }
            }
          }
        },
        "responses": {
          "default": {
            "description": "Default fallback response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "oneOf": [
                        {
                          "type": "boolean",
                          "enum": [
                            false
                          ]
                        },
                        {
                          "type": "boolean",
                          "enum": [
                            true
                          ]
                        }
                      ]
                    },
                    "id": {
                      "type": "string"
                    },
                    "preferences": {
                      "type": "object",
                      "properties": {
                        "theme": {
                          "type": "string",
                          "enum": [
                            "light",
                            "dark",
                            "system"
                          ]
                        },
                        "notifications": {
                          "type": "object",
                          "properties": {
                            "email": {},
                            "push": {},
                            "frequency": {
                              "type": "string",
                              "enum": [
                                "never",
                                "daily",
                                "weekly"
                              ]
                            }
                          },
                          "required": [
                            "email",
                            "push",
                            "frequency"
                          ]
                        },
                        "roles": {
                          "type": "array",
                          "items": {
                            "type": "string",
                            "enum": [
                              "admin",
                              "editor",
                              "viewer"
                            ]
                          }
                        },
                        "metadata": {
                          "oneOf": [
                            {
                              "type": "object",
                              "properties": {}
                            }
                          ]
                        }
                      },
                      "required": [
                        "theme",
                        "notifications",
                        "roles"
                      ]
                    }
                  },
                  "required": [
                    "success",
                    "id",
                    "preferences"
                  ]
                }
              }
            }
          }
        }
      }
    }
  }
}
