        "summary": "Auto-generated GET /api/docs/open-api",
        "responses": {
          "default": {
            "description": "Generic status from T[\"status\"]",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {}
                }
              }
            }
          }
        },
        "tags": [
          "E-Commerce Platform"
